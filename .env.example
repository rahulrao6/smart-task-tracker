# Smart Task Tracker — Environment Configuration
# Copy this file to .env and update values for your environment

# Application
APP_NAME=Smart Task Tracker
APP_VERSION=1.0.0
DEBUG=false

# Database
# SQLite (default, no extra setup required):
DATABASE_URL=sqlite+aiosqlite:///./tasks.db
# PostgreSQL example:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tasktracker

# Security
SECRET_KEY=changeme-in-production

# CORS — comma-separated list of allowed origins
# Use * to allow all (development only)
ALLOWED_ORIGINS=*
# Production example:
# ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
